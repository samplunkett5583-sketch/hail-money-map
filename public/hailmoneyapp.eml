    }

    .menu-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .menu-row {
      width: 100%;
      background: var(--panel-2);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 14px 16px;
      color: var(--text);
