    function costDocOpenScore(doc) {
      if (!doc) return 0;
      var score =3D 0;
      if (doc.storage_path) score +=3D 8;
      if (doc.storage_url) score +=3D 4;
      if (doc.file_url) score +=3D 2;
      if (doc.dataUrl) score +=3D 1;
      return score;
