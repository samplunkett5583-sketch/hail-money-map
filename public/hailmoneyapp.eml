    /* ---------- Image compression helpers ---------- */
    function loadImageFromFile(file) {
      return new Promise(function (resolve, reject) {
        var url =3D URL.createObjectURL(file);
        var img =3D new Image();
        img.onload =3D function () {
          URL.revokeObjectURL(url);
          resolve(img);
        };
        img.onerror =3D function () {
          URL.revokeObjectURL(url);
          reject(new Error('image decode failed'));
        };
        img.src =3D url;
      });
    }

    function resizeToCanvas(img, maxDim) {
      var w =3D img.width, h =3D img.height;
      if (w > maxDim || h > maxDim) {
        if (w > h) { h =3D Math.round(h * maxDim / w); w =3D maxDim; }
        else       { w =3D Math.round(w * maxDim / h); h =3D maxDim; }
      }
      var c =3D document.createElement('canvas');
      c.width =3D w; c.height =3D h;
      c.getContext('2d').drawImage(img, 0, 0, w, h);
      return c;
    }

    function canvasToBlob(canvas, quality) {
      return new Promise(function (resolve) {
        canvas.toBlob(function (blob) { resolve(blob); }, 'image/jpeg',
quality);
      });
    }

    /** Process one file =E2=86=92 { thumbBlob, viewerBlob } */
    function processPhotoFile(file) {
      return loadImageFromFile(file).then(function (img) {
        var thumbCanvas  =3D resizeToCanvas(img, 260);
