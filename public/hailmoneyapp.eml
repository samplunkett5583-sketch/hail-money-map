    /**
     * Render all pages of a PDF dataUrl into canvases inside a container
div.
     * Returns a promise resolving to:
     *   { container, totalWidth, totalHeight, pages: [{ wrapper, width,
height, offsetTop }] }
     * Each page canvas is wrapped in a position:relative div (wrapper) so
overlays
     * can be absolutely positioned inside it with page-relative
coordinates.
     */
    function renderPdfPages(dataUrl, containerWidth) {
      var container =3D document.createElement('div');
      container.style.cssText =3D 'position:relative;width:100%;';
      var cw =3D containerWidth || 500;

      // Convert dataUrl to Uint8Array =E2=80=94 use fetch for large files,=
 atob
fallback
      var dataPromise;
      try {
        dataPromise =3D fetch(dataUrl).then(function (r) { return
r.arrayBuffer(); }).then(function (buf) {
          return new Uint8Array(buf);
        });
      } catch (e) {
        // Fallback for environments where fetch(dataUrl) fails
        var base64 =3D dataUrl.split(',')[1];
        var raw =3D atob(base64);
        var uint8 =3D new Uint8Array(raw.length);
        for (var i =3D 0; i < raw.length; i++) uint8[i] =3D raw.charCodeAt(=
i);
        dataPromise =3D Promise.resolve(uint8);
      }

      return dataPromise.then(function (uint8) {
        return pdfjsLib.getDocument({ data: uint8 }).promise;
      }).then(function (pdf) {
        var totalHeight =3D 0;
        var pages =3D [];
        var chain =3D Promise.resolve();
        for (var p =3D 1; p <=3D pdf.numPages; p++) {
          (function (pageNum) {
            chain =3D chain.then(function () {
              return pdf.getPage(pageNum).then(function (page) {
                var vp =3D page.getViewport({ scale: 1 });
                var scale =3D cw / vp.width;
                var scaledVp =3D page.getViewport({ scale: scale });
                var wrapper =3D document.createElement('div');
                wrapper.style.cssText =3D 'position:relative;width:100%;';
                wrapper.setAttribute('data-page-index', pageNum - 1);
                var canvas =3D document.createElement('canvas');
                canvas.width =3D scaledVp.width;
                canvas.height =3D scaledVp.height;
                canvas.style.cssText =3D 'width:100%;display:block;';
                wrapper.appendChild(canvas);
                container.appendChild(wrapper);
                var pageOffsetTop =3D totalHeight;
                totalHeight +=3D scaledVp.height;
                pages.push({ wrapper: wrapper, width: scaledVp.width,
height: scaledVp.height, offsetTop: pageOffsetTop });
                return page.render({ canvasContext:
canvas.getContext('2d'), viewport: scaledVp }).promise;
              });
            });
          })(p);
        }
        return chain.then(function () {
          return { container: container, totalWidth: cw, totalHeight:
totalHeight, pages: pages };
        });
      });
    }

