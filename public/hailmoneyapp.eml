    function costDocDedupKey(doc) {
      if (!doc) return '';
      return [
        String(doc.doc_type || '').trim().toLowerCase(),
        String(doc.file_name || '').trim().toLowerCase(),
        String(doc.amount || 0),
        String(doc.date || '').trim()
