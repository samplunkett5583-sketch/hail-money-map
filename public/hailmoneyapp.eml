        var doc =3D normalizeCostDoc(docs[i]);
        var key =3D costDocDedupKey(doc);
        if (!key) key =3D 'fallback|' + i;
        if (!map[key]) { map[key] =3D doc; continue; }
        var existing =3D map[key];
        var existingScore =3D costDocOpenScore(existing);
        var incomingScore =3D costDocOpenScore(doc);
        if (incomingScore > existingScore) { map[key] =3D doc; continue; }
        if (incomingScore =3D=3D=3D existingScore) {
          var existingTime =3D new Date(existing.uploaded_at || 0).getTime(=
)
|| 0;
          var incomingTime =3D new Date(doc.uploaded_at || 0).getTime() || =
0;
